# =====================================================================
# Azure OpenAI configuration for the /addiction/ flow
#
# Copy this file to .env.local and fill in real values for local
# development (`vercel dev`). NEVER commit .env.local — it is
# gitignored.
#
# In production, set these in the Vercel project's Environment
# Variables panel (Project Settings -> Environment Variables).
# =====================================================================

# Resource endpoint, no trailing slash, no path.
# Example: https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Azure OpenAI key (Key 1 or Key 2 from the Azure portal).
AZURE_OPENAI_API_KEY=replace-with-real-key

# API version, e.g. 2024-10-21
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment name (the name you gave the deployment in Azure AI Studio,
# NOT the underlying model name — though they often match).
AZURE_OPENAI_MODEL=gpt-4o-mini


# =====================================================================
# API Origin allowlist (optional)
#
# Comma-separated list of origins allowed to call the addiction API.
# When unset, the API allows the production URL by default and adds
# localhost variants in non-production builds.
#
# In Vercel, set per-scope:
#   - Production: leave unset OR set to your production origins
#       e.g. https://mind-eight-rose.vercel.app,https://yourcustomdomain.com
#   - Preview:    set to "*" if you want preview deploys to be testable
#                 from any origin (recommended for testing)
#   - Development: not used (Vercel dev uses .env.local instead)
# =====================================================================
ALLOWED_ORIGINS=
